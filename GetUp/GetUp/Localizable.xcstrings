    "TIME SAVED IN YOUR LIFE" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "ZEIT IN DEINEM LEBEN GESPART" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "TIEMPO AHORRADO EN TU VIDA" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "TEMPO RISPARMIATO NELLA TUA VITA" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "TEMPS GAGNÉ DANS TA VIE" } }
      }
    },
    "Versus the average sleep-in. Every morning you scan, you save your future self real minutes." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Verglichen mit dem durchschnittlichen Ausschlafen. Jeden Morgen, an dem du scannst, sparst du deinem zukünftigen Ich echte Minuten." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Frente a la media de dormir más de la cuenta. Cada mañana que escaneas, le ahorras minutos reales a tu yo futuro." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Rispetto alla media di chi resta a letto. Ogni mattina che scansioni, regali minuti veri al tuo io futuro." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Par rapport au temps moyen passé à traîner au lit. Chaque matin où tu scannes, tu offres de vraies minutes à ton futur toi." } }
      }
    },
    "Time to scan" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Scan-Zeit" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Tiempo hasta escanear" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Tempo per scansionare" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Temps avant scan" } }
      }
    },
