{
  "sourceLanguage" : "en",
  "version" : "1.0",
  "strings" : {

    "Choose your language" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Sprache wählen" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Elige tu idioma" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Scegli la tua lingua" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Choisis ta langue" } }
      }
    },
    "You can change this anytime in Settings." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Du kannst das jederzeit in den Einstellungen ändern." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Puedes cambiarlo cuando quieras en Ajustes." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Puoi cambiarla in qualsiasi momento nelle Impostazioni." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Tu peux la changer à tout moment dans les Réglages." } }
      }
    },
    "Language" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Sprache" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Idioma" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Lingua" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Langue" } }
      }
    },

    "Get out of bed.\nActually." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Steh auf.\nWirklich." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Sal de la cama.\nDe verdad." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Alzati dal letto.\nDavvero." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Sors du lit.\nVraiment." } }
      }
    },
    "GetUp only turns off when you walk\nyour phone to a tag in another room." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "GetUp geht erst aus, wenn du dein Telefon\nzu einem Tag in einem anderen Raum bringst." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "GetUp solo se apaga cuando llevas el móvil\na una etiqueta en otra habitación." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "GetUp si spegne solo quando porti il telefono\na un tag in un'altra stanza." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "GetUp ne s'éteint que lorsque tu apportes ton téléphone\nà un tag dans une autre pièce." } }
      }
    },
    "Get started" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Loslegen" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Empezar" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Inizia" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Commencer" } }
      }
    },
    "Continue" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Weiter" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Continuar" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Continua" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Continuer" } }
      }
    },
    "Skip for now" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Vorerst überspringen" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Omitir por ahora" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Salta per ora" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Ignorer pour l'instant" } }
      }
    },
    "Finish" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Fertig" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Finalizar" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Concludi" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Terminer" } }
      }
    },
    "Back" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Zurück" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Atrás" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Indietro" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Retour" } }
      }
    },

    "From Felix & Georg" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Von Felix & Georg" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "De Felix & Georg" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Da Felix & Georg" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "De la part de Felix & Georg" } }
      }
    },
    "We're two people who could never trust ourselves to actually get up. Every snooze button felt like a tiny betrayal." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wir sind zwei Leute, die sich selbst nie zugetraut haben, wirklich aufzustehen. Jede Snooze-Taste fühlte sich wie ein kleiner Verrat an." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Somos dos personas que nunca confiamos en levantarnos de verdad. Cada botón de repetir alarma se sentía como una pequeña traición." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Siamo due persone che non sono mai riuscite a fidarsi di sé stesse per alzarsi davvero. Ogni tasto snooze sembrava un piccolo tradimento." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Nous sommes deux personnes qui n'ont jamais pu se faire confiance pour vraiment se lever. Chaque bouton snooze ressemblait à une petite trahison." } }
      }
    },
    "So we built GetUp — a clean, simple way to make mornings easier. Once your feet hit the floor, the day starts." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Also haben wir GetUp gebaut — eine klare, einfache Art, Morgen leichter zu machen. Sobald deine Füße den Boden berühren, beginnt der Tag." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Así que creamos GetUp — una forma clara y sencilla de hacer las mañanas más fáciles. En cuanto tus pies tocan el suelo, empieza el día." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Così abbiamo costruito GetUp — un modo pulito e semplice per rendere le mattine più facili. Quando i tuoi piedi toccano il pavimento, la giornata inizia." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Alors nous avons créé GetUp — une façon simple et claire de rendre les matins plus faciles. Dès que tes pieds touchent le sol, la journée commence." } }
      }
    },
    "Felix and Georg, GetUp founders" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Felix und Georg, GetUp-Gründer" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Felix y Georg, fundadores de GetUp" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Felix e Georg, fondatori di GetUp" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Felix et Georg, fondateurs de GetUp" } }
      }
    },

    "Connect your tag" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Tag verbinden" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Conecta tu etiqueta" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Collega il tuo tag" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Connecte ton tag" } }
      }
    },
    "Pair your physical GetUp tag once.\nWe'll use it to know when you've\nactually walked to it." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Verbinde deinen GetUp-Tag einmalig.\nDamit wissen wir, wann du wirklich\nzu ihm hingegangen bist." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Empareja tu etiqueta GetUp una vez.\nAsí sabremos cuándo de verdad\nhas caminado hasta ella." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Abbina il tuo tag GetUp una sola volta.\nLo useremo per sapere quando ci\nsei davvero andato vicino." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Associe ton tag GetUp une seule fois.\nNous saurons ainsi quand tu y as\nvraiment marché." } }
      }
    },
    "Tag successfully linked." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Tag erfolgreich verbunden." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Etiqueta vinculada con éxito." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Tag collegato con successo." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Tag connecté avec succès." } }
      }
    },
    "Link your GetUp" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "GetUp verbinden" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Vincular GetUp" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Collega GetUp" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Lier GetUp" } }
      }
    },
    "Securely connect your tag" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Sicher mit deinem Tag verbinden" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Conecta tu etiqueta de forma segura" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Collega il tuo tag in sicurezza" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Connecte ton tag en toute sécurité" } }
      }
    },

    "Set up your alarm" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wecker einrichten" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Configura tu alarma" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Imposta la sveglia" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Configure ton réveil" } }
      }
    },
    "On the home screen, tap Add alarm to pick your wake time. We'll handle the rest — when it rings, walk to your tag." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Tippe auf dem Home-Screen auf „Wecker hinzufügen“, um deine Aufstehzeit zu wählen. Den Rest übernehmen wir — wenn er klingelt, gehst du zu deinem Tag." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "En la pantalla principal, toca Añadir alarma para elegir tu hora de despertar. Nos encargamos del resto — cuando suene, camina hasta tu etiqueta." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Nella schermata principale, tocca Aggiungi sveglia per scegliere l'orario. Al resto pensiamo noi — quando suona, vai al tuo tag." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Sur l'écran d'accueil, appuie sur Ajouter une alarme pour choisir l'heure du réveil. On s'occupe du reste — quand elle sonne, marche jusqu'à ton tag." } }
      }
    },
    "Tap Add alarm" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "„Wecker hinzufügen“ tippen" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Toca Añadir alarma" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Tocca Aggiungi sveglia" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Appuie sur Ajouter une alarme" } }
      }
    },
    "From the home screen." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Vom Home-Screen aus." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Desde la pantalla principal." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Dalla schermata principale." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Depuis l'écran d'accueil." } }
      }
    },
    "Pick a time" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Zeit wählen" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Elige una hora" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Scegli un orario" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Choisis une heure" } }
      }
    },
    "Whenever you want to wake up." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wann immer du aufwachen willst." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Cuando quieras despertarte." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Quando vuoi svegliarti." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Quand tu veux te réveiller." } }
      }
    },
    "Sleep tight" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Schlaf gut" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Que duermas bien" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Sogni d'oro" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Dors bien" } }
      }
    },
    "When it rings, walk to your tag." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wenn er klingelt, geh zu deinem Tag." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Cuando suene, camina hasta tu etiqueta." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Quando suona, vai al tuo tag." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Quand il sonne, marche jusqu'à ton tag." } }
      }
    },

    "Alarms Disabled" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wecker deaktiviert" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Alarmas desactivadas" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Sveglie disattivate" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Alarmes désactivées" } }
      }
    },
    "Enable in Settings to receive alarms" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "In Einstellungen aktivieren, um Wecker zu erhalten" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Activa en Ajustes para recibir alarmas" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Attiva nelle Impostazioni per ricevere le sveglie" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Active dans les Réglages pour recevoir les alarmes" } }
      }
    },
    "Fix" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Beheben" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Arreglar" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Risolvi" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Corriger" } }
      }
    },
    "Open Settings" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Einstellungen öffnen" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Abrir Ajustes" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Apri Impostazioni" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Ouvrir Réglages" } }
      }
    },
    "Cancel" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Abbrechen" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Cancelar" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Annulla" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Annuler" } }
      }
    },
    "Please enable alarms in Settings to use GetUp." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Bitte aktiviere Wecker in den Einstellungen, um GetUp zu nutzen." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Activa las alarmas en Ajustes para usar GetUp." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Attiva le sveglie nelle Impostazioni per usare GetUp." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Active les alarmes dans les Réglages pour utiliser GetUp." } }
      }
    },
    "Your alarms" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Deine Wecker" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Tus alarmas" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Le tue sveglie" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Tes alarmes" } }
      }
    },
    "%lld active" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "%lld aktiv" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "%lld activas" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "%lld attive" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "%lld actives" } }
      }
    },
    "No alarms yet" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Noch keine Wecker" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Aún no hay alarmas" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Nessuna sveglia" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Pas encore d'alarmes" } }
      }
    },
    "Add your first morning alarm to get started." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Füge deinen ersten Morgen-Wecker hinzu, um loszulegen." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Añade tu primera alarma matutina para empezar." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Aggiungi la tua prima sveglia mattutina per iniziare." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Ajoute ta première alarme du matin pour commencer." } }
      }
    },
    "Add alarm" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wecker hinzufügen" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Añadir alarma" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Aggiungi sveglia" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Ajouter une alarme" } }
      }
    },
    "Add new alarm" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Neuen Wecker hinzufügen" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Añadir nueva alarma" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Aggiungi nuova sveglia" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Ajouter une nouvelle alarme" } }
      }
    },
    "Progress" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Fortschritt" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Progreso" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Progressi" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Progrès" } }
      }
    },
    "Streak" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Serie" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Racha" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Serie" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Série" } }
      }
    },
    "Get up on time every day to build your streak." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Steh jeden Tag pünktlich auf, um deine Serie aufzubauen." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Levántate a tiempo cada día para mantener tu racha." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Alzati in tempo ogni giorno per costruire la tua serie." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Lève-toi à l'heure chaque jour pour construire ta série." } }
      }
    },
    "Menu" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Menü" } },
