    "Made for heavy sleepers." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Für Tiefschläfer gemacht." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Hecho para los que duermen profundamente." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Pensato per chi dorme sodo." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Conçu pour les gros dormeurs." } }
      }
    },
    "Data reset complete" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Daten-Reset abgeschlossen" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Restablecimiento de datos completo" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Ripristino dati completato" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Réinitialisation des données terminée" } }
      }
    },
    "Force-quit and relaunch GetUp to start fresh. (Swipe up from the bottom and swipe the app away.)" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Beende GetUp komplett und starte neu, um frisch zu beginnen. (Vom unteren Rand nach oben wischen und die App wegwischen.)" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Cierra GetUp por completo y vuelve a abrirla para empezar de cero. (Desliza hacia arriba desde abajo y desliza la app fuera.)" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Forza la chiusura e riapri GetUp per ricominciare da capo. (Scorri verso l'alto dal basso e fai uscire l'app.)" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Quitte complètement GetUp et relance-la pour repartir à zéro. (Glisse vers le haut depuis le bas et balaie l'app.)" } }
      }
    },

    "Scan to stop alarm" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Scannen, um Wecker zu stoppen" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Escanea para detener la alarma" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Scansiona per fermare la sveglia" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Scanne pour arrêter l'alarme" } }
      }
    },
    "Hold the top of your iPhone near your NFC tag." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Halte die Oberkante deines iPhones an deinen NFC-Tag." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Acerca la parte superior del iPhone a tu etiqueta NFC." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Avvicina la parte superiore dell'iPhone al tuo tag NFC." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Approche le haut de ton iPhone de ton tag NFC." } }
      }
    },
    "Alarm" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wecker" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Alarma" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Sveglia" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Alarme" } }
      }
    },
    "You're up." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Du bist wach." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Estás en pie." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Sei sveglio." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Tu es debout." } }
      }
    },
    "That's not your tag." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Das ist nicht dein Tag." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Esta no es tu etiqueta." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Questo non è il tuo tag." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Ce n'est pas ton tag." } }
      }
    },
    "Have a good morning." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Hab einen guten Morgen." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Que tengas buena mañana." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Buona giornata." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Passe une bonne matinée." } }
      }
    },
    "Try again." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Versuch's nochmal." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Inténtalo de nuevo." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Riprova." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Réessaie." } }
      }
    },
    "Emergency Stop" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Notfall-Stopp" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Parada de emergencia" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Stop d'emergenza" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Arrêt d'urgence" } }
      }
    },
    "Stop Alarm" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wecker stoppen" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Detener alarma" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Ferma sveglia" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Arrêter l'alarme" } }
      }
    },
    "Alright sleepyhead, due to regulations you do have a way out here. If your GetUp Tag is broken, you do not find it or you are unable to move, then there is a way. Hold the button for 20 seconds to stop the alarm. Use it wisely sleepyhead!" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Okay Schlafmütze, aus regulatorischen Gründen gibt's einen Notausgang. Wenn dein GetUp-Tag kaputt ist, du ihn nicht findest oder dich nicht bewegen kannst — halte den Knopf 20 Sekunden gedrückt, um den Wecker zu stoppen. Benutz das mit Bedacht, Schlafmütze!" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Vale, dormilón, por temas legales tienes una salida. Si tu etiqueta GetUp está rota, no la encuentras o no puedes moverte, hay una manera. Mantén pulsado el botón 20 segundos para detener la alarma. ¡Úsalo con cabeza, dormilón!" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Ok dormiglione, per ragioni normative hai una via d'uscita. Se il tuo tag GetUp è rotto, non lo trovi o non riesci a muoverti, c'è un modo. Tieni premuto il pulsante per 20 secondi per fermare la sveglia. Usalo con saggezza, dormiglione!" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "OK marmotte, pour des raisons réglementaires, tu as une porte de sortie. Si ton tag GetUp est cassé, que tu ne le retrouves pas ou que tu ne peux pas bouger, il y a un moyen. Maintiens le bouton 20 secondes pour arrêter l'alarme. À utiliser avec sagesse, marmotte !" } }
      }
    },
    "Mock NFC Scan" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "NFC-Scan simulieren" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Simular escaneo NFC" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Simula scansione NFC" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Simuler le scan NFC" } }
      }
    },

